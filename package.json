{
  "name": "@gammarinaldi/wa-gateway",
  "version": "1.1.3",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gammarinaldi/wa-gateway.git"
  },
  "bugs": {
    "url": "https://github.com/gammarinaldi/wa-gateway/issues"
  },
  "homepage": "https://github.com/gammarinaldi/wa-gateway#readme",
  "main": "dist/lib/core/index.js",
  "types": "dist/lib/core/index.d.ts",
  "files": [
    "dist",
    "prisma"
  ],
  "description": "A professional WhatsApp Gateway library and API built with Baileys and Next.js",
  "keywords": [
    "whatsapp",
    "baileys",
    "gateway",
    "automation",
    "api",
    "chatbot",
    "messaging"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "next build && tsc --project tsconfig.lib.json",
    "build:server": "tsc src/server.ts --outDir dist --esModuleInterop --moduleResolution bundler --module esnext --target esnext --allowJs --skipLibCheck",
    "start": "NODE_ENV=production node dist/server.js",
    "lint": "next lint",
    "postinstall": "npx prisma generate",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "axios": "^1.15.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "next": "15.0.3",
    "pino": "^9.1.0",
    "qrcode": "^1.5.3",
    "qrcode.react": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "redis": "^4.6.13",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.12.12",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^8",
    "eslint-config-next": "15.0.3",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.10.2",
    "typescript": "^5"
  }
}